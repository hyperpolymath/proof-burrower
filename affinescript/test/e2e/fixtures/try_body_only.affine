//
// E2E fixture: try block with body only (no catch, no finally).
// The result is the body value — simplest try form.

fn safe_add(x: Int, y: Int) -> Int {
  try {
    x + y
  }
}

fn main() -> Int {
  safe_add(10, 32)
}
