//
// E2E fixture: try/catch/finally — full three-clause form.
// Verifies that all three clauses type-check together correctly.

fn full_try(x: Int) -> Int {
  try {
    x * 3
  } catch {
    e => 0
  } finally {
    ()
  }
}

fn main() -> Int {
  full_try(7)
}
