# RattleScript — Hello World
# This is a .rattle file (Python-face AffineScript).
# You can also use .pyaff if you prefer.

def greet(name: String) -> String:
    "Hello, " + name + "!"

def main() -> ():
    let msg = greet("world")
    IO.println(msg)
