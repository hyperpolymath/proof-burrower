; Face stack rewired 2026-04-19:
;   - face.ml + face.mli now match the ADR-010 spec (face type,
;     face_error_vocab, detect_face — no AST-level dispatch).
;   - python_face.ml is a source-level text preprocessor per the
;     spec; exposes parse_string_python, parse_file_python,
;     preview_transform (used by test/test_e2e.ml §11).
;   - javascript_face / pseudocode_face deleted: their previous
;     content was WIP stubs against a non-existent AST and no test
;     exercised them.  Face slots in `type face` remain for CLI
;     dispatch when the preprocessors are written.
;
; `backends.ml` and `lib/backends/` were deleted (b981f90).
(library
 (name affinescript)
 (libraries sedlex menhirLib yojson unix str)
 ; ppx_jane dropped: code only uses [@@deriving show, eq, ord], all
 ; provided by ppx_deriving plugins.  ppx_jane transitively pulled in
 ; ppx_bin_prot / bin_prot whose runtime.js fires `joo_global_object`
 ; deprecation warnings under js_of_ocaml 6.2.  Narrower preprocess
 ; list removes that closure.
 (preprocess (pps ppx_deriving.show ppx_deriving.eq ppx_deriving.ord sedlex.ppx))
 (flags :standard -w -A))

; parser.mly -> module Parser generated by menhir, consumed by
; parse_driver.ml and parse.ml (via MenhirInterpreter).
(menhir
 (modules parser)
 (flags --table))
